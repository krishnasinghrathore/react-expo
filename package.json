{
  "name": "ultima-dashboard-web",
  "version": "1.0.0",
  "description": "A complete PrimeReact Ultima-themed dashboard built with React",
  "main": "app_example.tsx",
  "scripts": {
    "dev": "vite",
    "dev:tamagui": "echo '🎨 Starting Tamagui Dashboard... Access at http://localhost:3000' && vite",
    "dev:primereact": "echo '🚀 Starting PrimeReact Dashboard... Access at http://localhost:3000/primereact.html' && vite",
    "dev:wsl": "echo '🚀 Starting for WSL... Access at http://localhost:3000' && vite",
    "build": "tsc && vite build",
    "build:tamagui": "tsc && vite build --config vite.config.ts",
    "build:primereact": "tsc && vite build --config vite.config.ts",
    "preview": "vite preview",
    "preview:primereact": "vite preview --open /primereact.html",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "chart.js": "^4.5.0",
    "lucide-react": "^0.263.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
  },
  "keywords": [
    "react",
    "dashboard",
    "primereact",
    "ultima",
    "admin",
    "ui",
    "components"
  ],
  "author": "Your Name",
  "license": "MIT"
}
